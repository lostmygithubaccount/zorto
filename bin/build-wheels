#!/usr/bin/env bash
set -euo pipefail
cd "$(dirname "${BASH_SOURCE[0]}")/.."

# Pin manylinux compatibility to manylinux2014 (glibc 2.17) for Linux wheel
# builds. Without an explicit --compatibility, maturin tags wheels with the
# host runner's glibc — release runners (ubuntu-latest = glibc 2.39) were
# producing manylinux_2_39 wheels that pip / uv refuse to install on Ubuntu
# 22.04 (2.35), Debian 12 (2.36), RHEL 9 (2.34), or Amazon Linux 2023 (2.34).
# manylinux2014 is the broadest reasonable target and covers ~all distros
# people actually run.
echo "Building zorto wheels..."
if [[ "$*" == *linux* ]]; then
  uv run maturin build --release --compatibility manylinux2014 "$@"
else
  uv run maturin build --release "$@"
fi

echo "Wheel build complete!"
