#!/usr/bin/env bash
set -euo pipefail

export PATH="$HOME/.local/bin:$HOME/.cargo/bin:$PATH"

"$(dirname "$0")/setup-netlify"

PYTHON_BIN=""
if command -v mise >/dev/null 2>&1; then
    PYTHON_BIN="$(mise which python3 2>/dev/null || mise which python 2>/dev/null || true)"
fi
if [[ -z "$PYTHON_BIN" ]]; then
    PYTHON_BIN="$(command -v python3 || command -v python || true)"
fi
if [[ -n "$PYTHON_BIN" ]]; then
    PYTHON_PREFIX="$(cd "$(dirname "$PYTHON_BIN")/.." && pwd)"
    for lib_dir in "$PYTHON_PREFIX/lib" "$PYTHON_PREFIX/lib64"; do
        if [[ -d "$lib_dir" ]]; then
            export LD_LIBRARY_PATH="$lib_dir${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}"
            echo "Added Python library path: $lib_dir"
        fi
    done
fi

exec "$(dirname "$0")/../website/bin/build"
